#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Environment variables
.env
.env.local

# Editor/IDE
.idea/
.vscode/

# Build artifacts
bin/
kubeorch-core
kubeorch-core.exe
*.exe

# Logs
*.log
logs/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
kubeorch

tmp/
# Claude Code rules
CLAUDE.md

# Build artifacts
core
main
